DATABASE_URL="postgresql://zeno:zeno_dev@localhost:5435/zeno?schema=public"
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# Moonshot AI (Kimi) — OpenAI-compatible vendor. Only needed if an agent is
# configured with the MOONSHOT provider.
MOONSHOT_API_KEY=sk-your-moonshot-key
# Optional: override the Moonshot base URL (default https://api.moonshot.ai/v1;
# use https://api.moonshot.cn/v1 for the mainland-China endpoint).
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Payment
PAYMENT_PROVIDER=mock                          # stripe | payu | mock
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYU_MERCHANT_ID=
PAYU_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_... # exposed to client

# Email — verification codes + magic links (lib/email). See docs/RESEND-EMAIL-SETUP.md.
# mock (default): prints the code + link to the server log, sends nothing.
# resend: sends for real via Resend — requires RESEND_API_KEY and EMAIL_FROM.
EMAIL_PROVIDER=mock                            # resend | mock
RESEND_API_KEY=re_...                          # Resend account API key
# Sender address. MUST be on a domain you verified in Resend, or the send is
# rejected. Interim: your verified personal domain. Switching to the Zeno
# domain later is just this line + RESEND_API_KEY — no code change.
EMAIL_FROM=Zeno <auth@your-verified-domain.com>

# Auth
JWT_SECRET=change-this-to-a-random-256-bit-secret
ADMIN_EMAIL=admin@zeno.ro
ADMIN_PASSWORD=change-this-in-production

# Compliance / Security
ENCRYPTION_KEY=your-64-character-hex-string-representing-32-bytes
REPORTS_PATH=./tmp/reports

# App — the ONE base for absolute links (verification emails, payment
# returns). Dev runs on port 3001; a wrong port mints dead magic links.
APP_URL=http://localhost:3001

# Sentry (Error Tracking + Performance)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# PostHog (Product Analytics)
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.posthog.com

# OpenTelemetry (Tracing) — disabled by default
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=zeno-agent
