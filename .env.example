DATABASE_URL="postgresql://zeno:zeno_dev@localhost:5435/zeno?schema=public"
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Payment
PAYMENT_PROVIDER=mock                          # stripe | payu | mock
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYU_MERCHANT_ID=
PAYU_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_... # exposed to client

# Email
EMAIL_PROVIDER=mock                            # resend | mock
RESEND_API_KEY=re_...
EMAIL_FROM=Zeno <noreply@zeno.ro>

# Auth
JWT_SECRET=change-this-to-a-random-256-bit-secret
ADMIN_EMAIL=admin@zeno.ro
ADMIN_PASSWORD=change-this-in-production

# Compliance / Security
ENCRYPTION_KEY=your-64-character-hex-string-representing-32-bytes
REPORTS_PATH=./tmp/reports

# App
APP_URL=http://localhost:3001

# Sentry (Error Tracking + Performance)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# PostHog (Product Analytics)
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.posthog.com

# OpenTelemetry (Tracing) — disabled by default
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=zeno-agent
