# ─────────────────────────────────────────────────────
# Zeno Production Environment Variables
# ─────────────────────────────────────────────────────
# Copy to .env and fill in real values before deploying.
# On Azure App Service, set these in Configuration > Application Settings.

# App
NODE_ENV=production
APP_URL=https://use-zeno.com
PORT=3000

# Database (Azure Database for PostgreSQL Flexible Server)
DATABASE_URL="postgresql://user:password@zeno-db.postgres.database.azure.com:5432/zeno?sslmode=require"

# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# Moonshot AI (Kimi) — OpenAI-compatible vendor. Only required when an agent
# uses the MOONSHOT provider. Optional MOONSHOT_BASE_URL overrides the region
# endpoint (default https://api.moonshot.ai/v1).
MOONSHOT_API_KEY=sk-...
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Auth
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Security
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Payment
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_...
EMAIL_FROM=Zeno <noreply@use-zeno.com>

# Monitoring — Sentry
# Create project at sentry.io, get DSN from Settings > Projects > Client Keys
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org
SENTRY_PROJECT=zeno

# Analytics — PostHog
# Create project at eu.posthog.com, get API key from Settings > Project > API Key
POSTHOG_API_KEY=phc_...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
POSTHOG_HOST=https://eu.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Reports
REPORTS_PATH=/app/data/reports

# Admin
ADMIN_EMAIL=admin@use-zeno.com
ADMIN_PASSWORD=change-this-in-production
